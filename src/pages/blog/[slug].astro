---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((p) => ({ params: { slug: p.id }, props: { post: p } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description ?? post.data.title}
>
  <article class="prose">
    <h1>{post.data.title}</h1>
    {
      post.data.pubDate && (
        <p>
          <small>
            <span id="post-date" data-pubdate={post.data.pubDate}>
              {new Date(post.data.pubDate).toLocaleDateString('es-ES')}
            </span>
          </small>
        </p>
      )
    }
    <Content />
  </article>
</BaseLayout>

<script>
  // @ts-nocheck
  function updatePostDate() {
    const el = document.getElementById('post-date');
    if (!el) return;
    const raw = el.getAttribute('data-pubdate');
    if (!raw) return;
    const lang = document.documentElement.lang === 'en' ? 'en' : 'es';
    const locale = lang === 'en' ? 'en-US' : 'es-ES';
    try {
      el.textContent = new Date(raw).toLocaleDateString(locale);
    } catch (e) {}
  }
  updatePostDate();
  window.addEventListener('lang-change', updatePostDate);
</script>
