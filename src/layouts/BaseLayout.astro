---
import Nav from '../components/Nav.astro';
import '../styles/global.css';
import en from '../i18n/en.json';
import es from '../i18n/es.json';

const {
  title = 'Martin Ruiz — Portafolio',
  description = 'Portafolio de Martin Ruiz',
  og = {
    title,
    description,
    type: 'website',
    url: 'https://martinruiz.dev',
    image: `${Astro.site?.origin ?? 'https://martinruiz.dev'}/og-default.jpg`,
  },
} = Astro.props as {
  title?: string;
  description?: string;
  og?: {
    title: string;
    description: string;
    type: string;
    url: string;
    image: string;
  };
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Martin Ruiz',
  url: 'https://martinruiz.dev',
  sameAs: ['https://www.linkedin.com/in/martin-ruizn/'],
};
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:title" content={og.title} />
    <meta property="og:description" content={og.description} />
    <meta property="og:type" content={og.type} />
    <meta property="og:url" content={og.url} />
    <meta property="og:image" content={og.image} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={og.title} />
    <meta name="twitter:description" content={og.description} />
    <meta name="twitter:image" content={og.image} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <script define:vars={{ en, es }}>
      window.__i18n__ = { en, es };
      window.__t__ = function (key) {
        try {
          const lang = (document.documentElement.lang === 'en' ? 'en' : 'es');
          const dict = window.__i18n__[lang] || window.__i18n__.es;
          const value = key.split('.').reduce(function (o, k) { return o && o[k]; }, dict);
          return typeof value === 'string' ? value : key;
        } catch (e) {
          return key;
        }
      };
    </script>

    {
      /* Ejemplo de override por página:
    <BaseLayout og={{ ...og, title: 'Página X', url: 'https://martinruiz.dev/x' }}>
      ...
    </BaseLayout>
    */
    }
  </head>
  <body>
    <Nav />
    <main class="container py-10">
      <slot />
    </main>
    <script>
      (function () {
        function updateAriaLabels() {
          if (typeof window.__t__ !== 'function') return;
          var fn = window.__t__;
          var langBtn = document.querySelector('[data-lang-toggle]');
          if (langBtn) langBtn.setAttribute('aria-label', fn('aria.changeLanguage'));
          var themeBtn = document.querySelector('[data-theme-toggle]');
          if (themeBtn) themeBtn.setAttribute('aria-label', fn('aria.toggleTheme'));
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', updateAriaLabels);
        } else {
          updateAriaLabels();
        }
        window.addEventListener('lang-change', updateAriaLabels);
      })();
    </script>
  </body>
</html>
