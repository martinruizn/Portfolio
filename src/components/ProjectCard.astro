---
const {
  title,
  teaser,
  titleKey,
  teaserKey,
  year,
  tags = [],
  href,
  image,
} = Astro.props as {
  title: string;
  teaser?: string;
  titleKey?: string;
  teaserKey?: string;
  year?: number;
  tags?: string[];
  href: string;
  image?: string;
};
const isExternal = href.startsWith('http');
const previewUrl = image || (isExternal ? `https://s.wordpress.com/mshots/v1/${encodeURIComponent(href)}?w=800&h=450` : undefined);
---

<a
  href={href}
  class="card group block overflow-hidden !p-0 !shadow-lg hover:!shadow-xl"
  target={isExternal ? '_blank' : undefined}
  rel={isExternal ? 'noopener noreferrer' : undefined}
>
  {
    previewUrl && (
      <div class="aspect-video w-full overflow-hidden border-b border-neutral-100 bg-neutral-50 dark:border-neutral-800 dark:bg-neutral-900">
        <img
          src={previewUrl}
          alt={title}
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
          loading="lazy"
        />
      </div>
    )
  }
  <div class="p-5">
    <div class="flex items-start justify-between gap-4">
      <div class="min-w-0">
        <h3 class="truncate text-lg font-semibold group-hover:text-brand transition-colors">
          {titleKey ? (
            <span data-i18n-title={titleKey}>{title}</span>
          ) : (
            title
          )}
        </h3>
        {
          (teaser || teaserKey) && (
            <p class="mt-2 text-sm text-neutral-600 line-clamp-2 dark:text-neutral-300">
              {teaserKey ? (
                <span data-i18n-teaser={teaserKey}>{teaser}</span>
              ) : (
                teaser
              )}
            </p>
          )
        }
        {
          tags.length > 0 && (
            <ul class="mt-4 flex flex-wrap gap-2 text-[10px] uppercase tracking-wider font-bold text-neutral-500 dark:text-neutral-400">
              {tags.map((t) => (
                <li class="rounded-full bg-neutral-100 px-2.5 py-0.5 dark:bg-neutral-800">
                  {t}
                </li>
              ))}
            </ul>
          )
        }
      </div>
      {
        typeof year === 'number' && (
          <span class="shrink-0 text-sm text-neutral-400">{year}</span>
        )
      }
    </div>
  </div>
</a>

