---
const links = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog' },
];
import ThemeToggle from './ThemeToggle.astro';
import LangToggle from './LangToggle.astro';
import { getT, onLangChange } from '../i18n/index.ts';
---

<nav
  class="sticky top-0 z-50 bg-white/70 backdrop-blur transition-all data-[compact=true]:shadow-md dark:bg-neutral-950/70"
>
  <div
    class="container relative flex h-14 items-center transition-all"
    data-nav-inner
  >
    <a href="/" class="inline-flex items-center gap-2" aria-label="Inicio">
      <img
        src="/logo.png"
        alt="Martin Ruiz"
        width="120"
        height="24"
        class="h-12 w-auto block transition-all data-[compact=true]:h-8 dark:hidden"
      />
      <img
        src="/logo-dark.png"
        alt="Martin Ruiz"
        width="120"
        height="24"
        class="h-12 w-auto hidden transition-all data-[compact=true]:h-8 dark:block"
      />
    </a>
    <div
      class="flex-1 flex justify-center items-center gap-4 transition-all data-[compact=true]:gap-3"
    >
      <div
        data-pills
        class="relative rounded-full bg-white/80 p-1 shadow-sm backdrop-blur transition-all data-[compact=true]:scale-90 data-[compact=true]:p-0.5 dark:bg-neutral-900/70"
      >
        <div
          class="flex items-center gap-2 transition-all data-[compact=true]:gap-1"
        >
          {
            links.map((l) => {
              const currentPath = Astro.url.pathname;
              const active =
                l.href === '/'
                  ? currentPath === '/'
                  : currentPath.startsWith(l.href);
              return (
                <a
                  href={l.href}
                  aria-current={active ? 'page' : undefined}
                  aria-label={l.label}
                  class={[
                    'inline-flex items-center h-10 rounded-full transition-all data-[compact=true]:h-8 data-[compact=true]:text-xs',
                    active
                      ? 'pl-2 pr-4 bg-neutral-900 text-white dark:bg-white dark:text-neutral-900 data-[compact=true]:pl-2 data-[compact=true]:pr-3'
                      : 'p-2 bg-neutral-100 text-neutral-700 hover:bg-neutral-200 dark:bg-neutral-800 dark:text-neutral-300 dark:hover:bg-neutral-700 data-[compact=true]:p-1.5',
                  ].join(' ')}
                >
                  {l.label === 'Home' ? (
                    <svg
                      width="18"
                      height="18"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                      class="shrink-0 transition-all data-[compact=true]:scale-90"
                      fill="currentColor"
                    >
                      <path d="M12 3.172 3 10v10a1 1 0 0 0 1 1h6v-6h4v6h6a1 1 0 0 0 1-1V10l-9-6.828z" />
                    </svg>
                  ) : (
                    <svg
                      width="18"
                      height="18"
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                      class="shrink-0 transition-all data-[compact=true]:scale-90"
                      fill="currentColor"
                    >
                      <path d="M4 5a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H9l-5 4v-4a2 2 0 0 1-2-2V5z" />
                    </svg>
                  )}
                  <span
                    aria-hidden="true"
                    class={[
                      'overflow-hidden text-sm transition-all duration-300',
                      active
                        ? 'ml-1.5 max-w-[160px] opacity-100'
                        : 'ml-0 max-w-0 opacity-0',
                    ].join(' ')}
                  >
                    {l.label}
                  </span>
                </a>
              );
            })
          }
        </div>
      </div>
    </div>
    <div
      class="ml-auto flex items-center gap-3 transition-all data-[compact=true]:scale-90"
      data-actions
    >
      <LangToggle />
      <ThemeToggle />
    </div>

    <script type="module">
      import { getT, onLangChange } from '/src/i18n/index.ts';
      // Replace labels from i18n on language change (client-side enhancement)
      const t = (path) => {
        try {
          return getT(document.documentElement.lang)(path);
        } catch {
          return path;
        }
      };
      const updateNavLabels = () => {
        const links = document.querySelectorAll('nav a[aria-label]');
        links.forEach((a) => {
          const href = a.getAttribute('href');
          const key =
            href === '/'
              ? 'nav.home'
              : href?.startsWith('/blog')
                ? 'nav.blog'
                : '';
          if (!key) return;
          a.setAttribute('aria-label', t(key));
          const span = a.querySelector('span[aria-hidden]');
          if (span) span.textContent = t(key);
        });
      };
      updateNavLabels();
      onLangChange(() => updateNavLabels());
      // Compact navbar on scroll
      const nav = document.querySelector('nav');
      const inner = document.querySelector('[data-nav-inner]');
      const actions = document.querySelector('[data-actions]');
      const pills = document.querySelector('[data-pills]');
      const applyCompact = () => {
        const compact = window.scrollY > 8;
        if (nav) nav.setAttribute('data-compact', String(compact));
        if (inner) inner.setAttribute('data-compact', String(compact));
        if (actions) actions.setAttribute('data-compact', String(compact));
        if (pills) pills.setAttribute('data-compact', String(compact));
        document
          .querySelectorAll('nav a[aria-label]')
          .forEach((a) => a.setAttribute('data-compact', String(compact)));
      };
      applyCompact();
      window.addEventListener('scroll', applyCompact, { passive: true });
      window.addEventListener('resize', applyCompact);
      const main = document.querySelector('main');
      // Fade-in on load
      if (main) {
        main.classList.add('page-enter');
        setTimeout(() => main.classList.remove('page-enter'), 500);
      }
      // Intercept nav clicks for a short fade-out
      document.querySelectorAll('a[href^="/"]').forEach((a) => {
        a.addEventListener('click', (e) => {
          const url = new URL(a.href, location.origin);
          if (url.origin !== location.origin) return; // external
          if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return; // new tab, etc
          if (!main) return;
          e.preventDefault();
          main.classList.add('page-exit');
          setTimeout(() => {
            window.location.href = a.href;
          }, 380);
        });
      });
    </script>
  </div>
</nav>
